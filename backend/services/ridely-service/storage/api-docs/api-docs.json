{
    "openapi": "3.0.0",
    "info": {
        "title": "Ridely Service",
        "description": "Provide Taxi services",
        "version": "1.0"
    },
    "paths": {
        "/": {
            "get": {
                "tags": [
                    "Public"
                ],
                "summary": "Root endpoint",
                "operationId": "9a1fcb6838228d4c219920618151d5bd",
                "responses": {
                    "200": {
                        "description": "Success response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RootSchema"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "tags": [
                    "Public"
                ],
                "summary": "Health check endpoint",
                "operationId": "1b08f26c6d3e6712513ec64ace17c564",
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/v1/drivers": {
            "get": {
                "tags": [
                    "Driver"
                ],
                "summary": "Lista os motoristas com filtros opcionais",
                "operationId": "d7e939814aa58b3a941ed13b4b77955e",
                "parameters": [
                    {
                        "name": "offset",
                        "in": "query",
                        "description": "Deslocamento (ponto de início da listagem)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Quantidade de resultados por página (máx: 100)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "maximum": 100,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "order_by",
                        "in": "query",
                        "description": "Campo para ordenação (ex: name, created_at)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "sort_by",
                        "in": "query",
                        "description": "Direção da ordenação: asc ou desc",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "asc",
                                "desc"
                            ]
                        }
                    },
                    {
                        "name": "fields",
                        "in": "query",
                        "description": "Campos específicos a retornar (ex: name,available)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de motoristas",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Driver"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Erro de validação dos critérios"
                    },
                    "422": {
                        "description": "Outros erros"
                    },
                    "401": {
                        "description": "Não autorizado"
                    }
                }
            },
            "post": {
                "tags": [
                    "Driver"
                ],
                "summary": "Cria um novo motorista",
                "operationId": "616886d5a7effb20d218264e6804538a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "car"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Carlos"
                                    },
                                    "car": {
                                        "$ref": "#/components/schemas/Car"
                                    },
                                    "available": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Driver criado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Driver"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/drivers/{id}": {
            "delete": {
                "tags": [
                    "Driver"
                ],
                "summary": "Remove um motorista",
                "operationId": "3670a9b76c6831f3c02d896166bb485a",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do driver",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Driver removido com sucesso"
                    },
                    "404": {
                        "description": "Driver não encontrado"
                    }
                }
            }
        },
        "/api/v1/drivers/{id}/open-rides": {
            "get": {
                "tags": [
                    "Driver"
                ],
                "summary": "Lista corridas abertas para um motorista",
                "operationId": "22eae3a965c896cdab0250aad9391f3e",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do driver",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de rides abertas",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Ride"
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Nenhuma corrida aberta",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "No rides waiting to be accepted"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/rides/{id}": {
            "get": {
                "tags": [
                    "Ride"
                ],
                "summary": "Buscar detalhes de uma corrida",
                "operationId": "ba49c05c73d20b23b3c7e0f8be7fecb6",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID da corrida",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detalhes da corrida",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RideFull"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Corrida não encontrada"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Ride"
                ],
                "summary": "Remover uma corrida",
                "operationId": "b8196402ca7419128eefa197acd4624a",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID da corrida",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Corrida removida"
                    },
                    "404": {
                        "description": "Corrida não encontrada"
                    }
                }
            }
        },
        "/api/v1/rides/request": {
            "post": {
                "tags": [
                    "Ride"
                ],
                "summary": "Solicitar motorista",
                "operationId": "ea006005f9b5cab61ee6de4034d9edb2",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "passenger",
                                    "pick_up",
                                    "drop_off"
                                ],
                                "properties": {
                                    "passenger": {
                                        "$ref": "#/components/schemas/Passenger"
                                    },
                                    "pick_up": {
                                        "type": "string",
                                        "example": "Rua X, 200"
                                    },
                                    "drop_off": {
                                        "type": "string",
                                        "example": "Av. Brasil, 1000"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Corrida criada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RideFull"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Não há motoristas disponíveis",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "We do not have drivers available"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/rides/cancel": {
            "post": {
                "tags": [
                    "Ride"
                ],
                "summary": "Cancelar corrida",
                "operationId": "f0b2a58f95283b96bf6b570afa0009f8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Corrida cancelada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RideSimple"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Corrida não encontrada"
                    }
                }
            }
        },
        "/api/v1/rides/accept": {
            "post": {
                "tags": [
                    "Ride"
                ],
                "summary": "Aceitar corrida",
                "operationId": "6651f698831a8d0d2517b14b58b30666",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Corrida aceita",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "accepted"
                                        },
                                        "drop_off": {
                                            "type": "string",
                                            "example": "Av. Brasil, 1000"
                                        },
                                        "pick_up": {
                                            "type": "string",
                                            "example": "Rua X, 200"
                                        },
                                        "passenger": {
                                            "$ref": "#/components/schemas/Passenger"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Corrida ou motorista não encontrado"
                    }
                }
            }
        },
        "/api/v1/rides/refuse": {
            "post": {
                "tags": [
                    "Ride"
                ],
                "summary": "Recusar corrida",
                "operationId": "2c2f4225b8b9d69cb6e476bfdf465318",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Corrida recusada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "refused"
                                        },
                                        "drop_off": {
                                            "type": "string",
                                            "example": "Av. Brasil, 1000"
                                        },
                                        "pick_up": {
                                            "type": "string",
                                            "example": "Rua X, 200"
                                        },
                                        "passenger": {
                                            "$ref": "#/components/schemas/Passenger"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Corrida não encontrada"
                    }
                }
            }
        },
        "/api/v1/rides/finish": {
            "post": {
                "tags": [
                    "Ride"
                ],
                "summary": "Finalizar corrida",
                "operationId": "437aa54038d63c9673f1eea4d12eb8fa",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id",
                                    "price"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 25
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Corrida finalizada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "finished"
                                        },
                                        "drop_off": {
                                            "type": "string",
                                            "example": "Av. Brasil, 1000"
                                        },
                                        "price": {
                                            "type": "number",
                                            "format": "float",
                                            "example": 25
                                        },
                                        "passenger": {
                                            "$ref": "#/components/schemas/Passenger"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Corrida não encontrada"
                    }
                }
            }
        },
        "/api/v1/drivers/{driverId}/open-rides": {
            "get": {
                "tags": [
                    "Ride"
                ],
                "summary": "Listar corridas abertas para motorista",
                "operationId": "29adaafeccc75b914e9d80fbee4f911e",
                "parameters": [
                    {
                        "name": "driverId",
                        "in": "path",
                        "description": "ID do motorista",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de corridas abertas",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/RideSimple"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Motorista indisponível",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Driver is not available"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Nenhuma corrida aberta",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "No rides waiting to be accepted"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Car": {
                "required": [
                    "license_plate",
                    "model",
                    "color"
                ],
                "properties": {
                    "license_plate": {
                        "type": "string",
                        "example": "ABC1234"
                    },
                    "model": {
                        "type": "string",
                        "example": "Fiat Uno"
                    },
                    "color": {
                        "type": "string",
                        "example": "Vermelho"
                    }
                },
                "type": "object"
            },
            "Driver": {
                "required": [
                    "id",
                    "name",
                    "car",
                    "available"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Carlos"
                    },
                    "car": {
                        "$ref": "#/components/schemas/Car"
                    },
                    "available": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "DriverShort": {
                "required": [
                    "name",
                    "car"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Carlos"
                    },
                    "car": {
                        "$ref": "#/components/schemas/Car"
                    }
                },
                "type": "object"
            },
            "Passenger": {
                "required": [
                    "name",
                    "email"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Maria"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "maria@email.com"
                    }
                },
                "type": "object"
            },
            "RideFull": {
                "required": [
                    "id",
                    "status",
                    "pick_up",
                    "drop_off"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "status": {
                        "type": "string",
                        "example": "requested"
                    },
                    "pick_up": {
                        "type": "string",
                        "example": "Rua X, 200"
                    },
                    "drop_off": {
                        "type": "string",
                        "example": "Av. Brasil, 1000"
                    },
                    "driver": {
                        "$ref": "#/components/schemas/DriverShort"
                    },
                    "passenger": {
                        "$ref": "#/components/schemas/Passenger"
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 25
                    }
                },
                "type": "object"
            },
            "Ride": {
                "required": [
                    "id",
                    "status",
                    "drop_off",
                    "pick_up",
                    "passenger"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 10
                    },
                    "status": {
                        "type": "string",
                        "example": "waiting"
                    },
                    "drop_off": {
                        "type": "string",
                        "example": "Av. Brasil, 1000"
                    },
                    "pick_up": {
                        "type": "string",
                        "example": "Rua X, 200"
                    },
                    "passenger": {
                        "$ref": "#/components/schemas/Passenger"
                    }
                },
                "type": "object"
            },
            "RideSimple": {
                "required": [
                    "id",
                    "status",
                    "pick_up",
                    "drop_off"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "status": {
                        "type": "string",
                        "example": "requested"
                    },
                    "pick_up": {
                        "type": "string",
                        "example": "Rua X, 200"
                    },
                    "drop_off": {
                        "type": "string",
                        "example": "Av. Brasil, 1000"
                    }
                },
                "type": "object"
            },
            "RootSchema": {
                "required": [
                    "app"
                ],
                "properties": {
                    "app": {
                        "type": "string",
                        "example": "ridely-service:1.0.0"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Public",
            "description": "Public"
        },
        {
            "name": "Driver",
            "description": "Driver"
        },
        {
            "name": "Ride",
            "description": "Ride"
        }
    ]
}