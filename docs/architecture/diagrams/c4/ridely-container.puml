@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

'-----------------------------------------
' Pessoa externa
'-----------------------------------------
Person(user, "Customer", "User who requests rides via mobile app")

'-----------------------------------------
' Sistemas
'-----------------------------------------
System_Boundary(kong, "API Gateway (Kong)") {
    Container(kongProxy, "Kong Proxy", "Kong Gateway", "Handles incoming HTTP requests, routes them to services, and applies plugins like rate limiting, logging, and authentication.")
    Container(kongIngress, "Kong Ingress Controller", "Kubernetes Controller", "Monitors Kubernetes ingress resources and configures Kong accordingly.")
}

System_Boundary(ridelyContext, "Ridely") {
    Container(ridelyService, "Ridely Service", "PHP/Laravel", "Main ride management API and business logic")

    ContainerDb(ridelyDatabase, "Ridely Database", "MySQL", "Stores user, ride, driver, and trip data")
    ContainerDb(redisCache, "Redis Cache Database", "Redis", "Used for caching data (pricing, sessions, etc)")


}

System_Boundary(authContext, "Auth Service") {
    Container(authService, "Auth Service", "Keycloak", "Handles user authentication and token issuance (OAuth2/OpenID)")
    ContainerDb(postgres, "Auth Service Database", "Postgres", "Stores authentication and identity data")
}

System_Boundary(pricingContext, "Pricing Service") {
    Container(pricingService, "Pricing Service", "Node.js", "Calculates dynamic ride pricing")
    ContainerDb(pricingDatabase, "Pricing Database", "Redis", "Stores temporary pricing calculations and estimations with automatic expiration (TTL)")
}

System(ridelyMobile, "Ridely Mobile", "Mobile Application")

'-----------------------------------------
' Sistemas externos
'-----------------------------------------
System_Boundary(messageBrokerContext, "Message Broker") {
    System_Ext(rabbitmq, "RabbitMQ", "Asynchronous messaging between services")

    ContainerQueue(rideRequested, "ride.requested", "RabbitMQ Topic", "Published when a user requests a ride")
    ContainerQueue(rideAccepted, "ride.accepted", "RabbitMQ Topic", "Published when a driver accepts a ride")
    ContainerQueue(rideCanceled, "ride.canceled", "RabbitMQ Topic", "Published when a user or driver cancels a ride")
    ContainerQueue(rideCompleted, "ride.completed", "RabbitMQ Topic", "Published when a ride is completed successfully")
    ContainerQueue(driverStatusChanged, "driver.status.changed", "RabbitMQ Topic", "Published when a driver's availability/status changes")

    ContainerQueue(pricingCalculated, "pricing.calculated", "RabbitMQ Topic", "Published when pricing estimation is calculated")
    ContainerQueue(pricingFailed, "pricing.failed", "RabbitMQ Topic", "Published when pricing estimation fails")

}

System_Boundary(observabilityContext, "Observability Stack") {
    System_Ext(prometheus, "Prometheus", "Scrapes and stores metrics")
    System_Ext(grafana, "Grafana", "Visualizes metrics and dashboards")
    System_Ext(jaeger, "Jaeger", "Distributed tracing for request flow")
    System_Ext(loki, "Loki", "Centralized logging for services")
}

'-----------------------------------------
' Relacionamentos
'-----------------------------------------
Rel(user, ridelyMobile, "Consumes taxi services via mobile app")
Rel(ridelyMobile, kongProxy, "Sends HTTPS requests")

Rel(kongProxy, authService, "Routes /auth requests")
Rel(kongProxy, ridelyService, "Routes /rides requests")
Rel(kongProxy, pricingService, "Routes /pricing requests")
Rel_L(kongIngress, kongProxy, "Configures routes and plugins")

Rel_D(authService, postgres, "Reads/Writes authentication data")
Rel_D(ridelyService, ridelyDatabase, "Reads/Writes ride and user data")
Rel_D(ridelyService, redisCache, "Reads/Writes cache")

Rel_U(ridelyService, rideRequested, "Publishes", "AMQP")
Rel_U(ridelyService, rideAccepted, "Publishes", "AMQP")
Rel_U(ridelyService, rideCanceled, "Publishes", "AMQP")
Rel_U(ridelyService, rideCompleted, "Publishes", "AMQP")
Rel_U(ridelyService, driverStatusChanged, "Publishes", "AMQP")


' TODO to be reviewed
'Rel_R(ridelyService, pricingService, "Requests fare estimates")
Rel_R(ridelyService, authService, "Validates tokens and API keys")
Rel_R(pricingService, authService, "Validates tokens and API keys")

Rel_D(pricingService, pricingDatabase, "Reads/Writes pricing cache")
' TODO to be reviewed
Rel_U(pricingService, rideRequested, "Consumes", "AMQP")
'Rel_U(pricingService, rideAccepted, "Consumes", "AMQP")
'Rel_U(pricingService, driverStatusChanged, "Consumes", "AMQP")

Rel_U(pricingService, pricingCalculated, "Publishes", "AMQP")
Rel_U(pricingService, pricingFailed, "Publishes", "AMQP")

' Observability
Rel(ridelyService, prometheus, "Exposes metrics")
Rel(ridelyService, loki, "Sends logs")
Rel(ridelyService, jaeger, "Sends traces")

Rel(pricingService, prometheus, "Exposes metrics")
Rel(pricingService, loki, "Sends logs")
Rel(pricingService, jaeger, "Sends traces")

Rel(grafana, prometheus, "Queries metrics")
Rel(grafana, loki, "Queries logs")
Rel(grafana, jaeger, "Visualizes traces")

SHOW_LEGEND()
@enduml
