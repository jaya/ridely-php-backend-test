@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml
title Visão de Implantação do Projeto Ridely - ECS e Kong

'-----------------------------------------
' People
'-----------------------------------------
Person(user, "Customer", "Uses the mobile app")

'-----------------------------------------
' Devices
'-----------------------------------------
Node(userDevice, "User Device", "iOS / Android") {
    Container(ridelyMobile, "Ridely Mobile", "Mobile App", "Frontend app to request rides")
}

'-----------------------------------------
' Kong Gateway (Auto-scaled Service on ECS)
'-----------------------------------------
Node(kongService, "Kong Gateway", "Amazon ECS Service") {
    Container(kongProxy, "Kong Proxy", "Kong Container", "Routes and filters HTTP requests")
    Container(kongIngress, "Ingress Controller", "Kubernetes-based or manually configured", "Configures routes and plugins")
}

'-----------------------------------------
' ECS Cluster
'-----------------------------------------
Node(ecsCluster, "ECS Cluster", "Amazon ECS") {

    Node(ridelyTask, "Ridely Task", "Fargate Task or EC2") {
        Container(ridelyService, "Ridely Service", "PHP/Laravel Container", "Ride management and event publishing")
    }

'    Node(pricingTask, "Pricing Task", "Fargate Task or EC2") {
'        Container(pricingService, "Pricing Service", "Node.js Container", "Calculates dynamic ride pricing")
'    }

    Node(authTask, "Auth Task", "Fargate Task or EC2") {
        Container(authService, "Auth Service", "Keycloak", "Handles authentication and tokens")
    }

'    Node(brokerTask, "Broker Task", "Fargate Task or EC2") {
'        Container(rabbitmq, "RabbitMQ", "Message Broker", "Publishes and subscribes to async events")
'    }

    Node(obsTask, "Observability Stack", "Fargate Task or EC2") {
        Container(prometheus, "Prometheus", "Metrics collection")
        Container(grafana, "Grafana", "Dashboard")
        Container(loki, "Loki", "Log aggregation")
        Container(jaeger, "Jaeger", "Tracing")
    }
}

'-----------------------------------------
' External Databases
'-----------------------------------------
Node(databases, "Managed DBs", "Amazon RDS / ElastiCache") {
    ContainerDb(mysql, "Ridely DB", "MySQL", "Stores ride/user data")
    ContainerDb(postgres, "Keycloak DB", "PostgreSQL", "Stores auth data")
    ContainerDb(redis, "Ridely Cache DB", "Redis", "TTL cache for data and pricing")
}

'-----------------------------------------
' Relationships
'-----------------------------------------
Rel(user, ridelyMobile, "Uses")
Rel(ridelyMobile, kongProxy, "Sends HTTPS requests")

Rel(kongProxy, ridelyService, "Routes /rides")
'Rel(kongProxy, pricingService, "Routes /pricing")
Rel(kongProxy, authService, "Routes /auth")

Rel(ridelyService, mysql, "Reads/Writes")
Rel(ridelyService, redis, "Reads")
'Rel(ridelyService, rabbitmq, "Publishes events")
Rel(ridelyService, authService, "Validates tokens")

'Rel(pricingService, redis, "Reads/Writes cache")
'Rel(pricingService, rabbitmq, "Publishes events")
'Rel(pricingService, authService, "Validates tokens")

Rel(authService, postgres, "Reads/Writes user data")

Rel(prometheus, ridelyService, "Scrapes metrics")
Rel(loki, ridelyService, "Collects logs")
Rel(jaeger, ridelyService, "Traces requests")

Rel(grafana, prometheus, "Queries")
Rel(grafana, loki, "Queries")
Rel(grafana, jaeger, "Visualizes")

@enduml
